import streamlit as st
import pickle
import numpy as np

# Load Model
model = pickle.load(open("salary_prediction_model.pkl", "rb"))

st.title("🎓 Student Placement Salary Predictor")

st.write("Enter Student Details")

# User Inputs
cgpa = st.number_input("CGPA", 0.0, 10.0, 7.5)
internships = st.number_input("Internships", 0, 10, 1)
coding = st.number_input("Coding Skills (1-10)", 1, 10, 5)
communication = st.number_input("Communication Skills (1-10)", 1, 10, 5)
projects = st.number_input("Projects", 0, 10, 2)
certifications = st.number_input("Certifications", 0, 20, 2)
aptitude = st.number_input("Aptitude Score", 0, 100, 70)
backlogs = st.number_input("Backlogs", 0, 10, 0)
attendance = st.number_input("Attendance (%)", 0, 100, 80)

# Prediction Button
if st.button("Predict Salary"):

    input_data = np.array([[
        cgpa,
        internships,
        coding,
        communication,
        projects,
        certifications,
        aptitude,
        backlogs,
        attendance
    ]])

    prediction = model.predict(input_data)

    st.success(f"Estimated Salary Package: {round(prediction[0], 2)} LPA")